<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nudge — Help us build something new</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --green: #2ECC8F;
    --green-dim: #1a9e6a;
    --green-pale: #e8faf3;
    --ink: #0f0f0f;
    --ink-mid: #444;
    --ink-light: #888;
    --surface: #fafaf8;
    --border: rgba(0,0,0,0.1);
    --radius: 12px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    font-weight: 400;
    background: var(--surface);
    color: var(--ink);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    width: 600px; height: 600px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(46,204,143,0.12) 0%, transparent 70%);
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    pointer-events: none;
  }

  .logo {
    font-family: 'DM Serif Display', serif;
    font-size: 15px;
    letter-spacing: 0.18em;
    color: var(--green-dim);
    text-transform: uppercase;
    margin-bottom: 3rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.1s ease forwards;
  }

  .hero-eyebrow {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--ink-light);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s ease forwards;
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.4rem, 6vw, 4rem);
    line-height: 1.15;
    color: var(--ink);
    max-width: 620px;
    margin-bottom: 1.4rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.3s ease forwards;
  }

  h1 em {
    font-style: italic;
    color: var(--green-dim);
  }

  .hero-sub {
    font-size: 16px;
    color: var(--ink-mid);
    max-width: 440px;
    line-height: 1.7;
    margin-bottom: 2.4rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.4s ease forwards;
  }

  .prize-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--green-pale);
    border: 1px solid rgba(46,204,143,0.3);
    border-radius: 99px;
    padding: 8px 18px;
    font-size: 13px;
    font-weight: 500;
    color: var(--green-dim);
    margin-bottom: 2.4rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s ease forwards;
  }

  .prize-pill::before {
    content: '●';
    font-size: 8px;
    color: var(--green);
  }

  .cta-btn {
    display: inline-block;
    background: var(--ink);
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    padding: 14px 32px;
    border-radius: 99px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: transform 0.15s, background 0.15s;
    opacity: 0;
    animation: fadeUp 0.6s 0.6s ease forwards;
  }

  .cta-btn:hover { background: #222; transform: translateY(-1px); }
  .cta-btn:active { transform: translateY(0); }

  .time-note {
    font-size: 12px;
    color: var(--ink-light);
    margin-top: 12px;
    opacity: 0;
    animation: fadeUp 0.6s 0.7s ease forwards;
  }

  .survey-section {
    max-width: 560px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .progress-wrap {
    margin-bottom: 2.5rem;
  }

  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--ink-light);
    margin-bottom: 8px;
  }

  .progress-track {
    height: 2px;
    background: var(--border);
    border-radius: 99px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--green);
    border-radius: 99px;
    transition: width 0.4s ease;
    width: 0%;
  }

  .step { display: none; }
  .step.active { display: block; animation: fadeUp 0.35s ease; }

  .step-tag {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--green-dim);
    margin-bottom: 8px;
  }

  .q-title {
    font-family: 'DM Serif Display', serif;
    font-size: 22px;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 6px;
  }

  .q-sub {
    font-size: 13px;
    color: var(--ink-light);
    margin-bottom: 20px;
    line-height: 1.6;
  }

  .concept-box {
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 18px;
    font-size: 14px;
    color: var(--ink-mid);
    line-height: 1.75;
    margin-bottom: 20px;
  }

  .concept-box strong { color: var(--ink); font-weight: 500; }

  .opts { display: flex; flex-direction: column; gap: 8px; margin-bottom: 24px; }

  .opt {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px 16px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    cursor: pointer;
    font-size: 14px;
    color: var(--ink-mid);
    background: white;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    user-select: none;
  }

  .opt:hover { border-color: rgba(46,204,143,0.4); background: var(--green-pale); }

  .opt.sel {
    border-color: var(--green);
    background: var(--green-pale);
    color: var(--ink);
  }

  .opt-indicator {
    width: 18px; height: 18px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    flex-shrink: 0;
    transition: border-color 0.15s, background 0.15s;
    position: relative;
  }

  .opt.sel .opt-indicator {
    background: var(--green);
    border-color: var(--green);
  }

  .opt.sel .opt-indicator::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 7px; height: 7px;
    border-radius: 50%;
    background: white;
  }

  .opt-sq { border-radius: 5px; }
  .opt.sel .opt-sq { background: var(--green); border-color: var(--green); }
  .opt.sel .opt-sq::after {
    content: '';
    position: absolute;
    top: 3px; left: 6px;
    width: 4px; height: 7px;
    border-right: 2px solid white;
    border-bottom: 2px solid white;
    transform: rotate(45deg);
  }

  .scale-row {
    display: flex;
    gap: 6px;
    margin-bottom: 8px;
  }

  .scale-btn {
    flex: 1;
    padding: 12px 4px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--ink-mid);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
    text-align: center;
  }

  .scale-btn:hover { border-color: rgba(46,204,143,0.4); background: var(--green-pale); }
  .scale-btn.sel { border-color: var(--green); background: var(--green-pale); color: var(--green-dim); }

  .scale-labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--ink-light);
    margin-bottom: 24px;
  }

  .field-label {
    display: block;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-mid);
    margin-bottom: 6px;
  }

  .text-input, .text-area {
    width: 100%;
    padding: 12px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: white;
    color: var(--ink);
    margin-bottom: 14px;
    outline: none;
    transition: border-color 0.15s;
  }

  .text-input:focus, .text-area:focus {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(46,204,143,0.12);
  }

  .text-area { resize: vertical; min-height: 90px; }

  .age-input { width: 100px; }

  .btn-row {
    display: flex;
    gap: 10px;
    align-items: center;
    margin-top: 8px;
  }

  .btn-next {
    background: var(--ink);
    color: white;
    border: none;
    border-radius: 99px;
    padding: 12px 28px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, transform 0.1s;
  }

  .btn-next:hover { background: #222; }
  .btn-next:active { transform: scale(0.98); }
  .btn-next:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-back {
    background: transparent;
    color: var(--ink-light);
    border: 1px solid var(--border);
    border-radius: 99px;
    padding: 12px 20px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-back:hover { background: white; }

  .err {
    font-size: 12px;
    color: #e24b4a;
    margin: -8px 0 14px;
    display: none;
  }

  .done-wrap {
    text-align: center;
    padding: 3rem 1rem;
  }

  .done-icon {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: var(--green-pale);
    border: 1px solid rgba(46,204,143,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-size: 22px;
  }

  .done-title {
    font-family: 'DM Serif Display', serif;
    font-size: 28px;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .done-sub {
    font-size: 14px;
    color: var(--ink-mid);
    line-height: 1.7;
    max-width: 380px;
    margin: 0 auto 1.5rem;
  }

  .done-note {
    font-size: 12px;
    color: var(--ink-light);
    background: white;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    line-height: 1.6;
    max-width: 380px;
    margin: 0 auto;
  }

  .submitting {
    font-size: 13px;
    color: var(--ink-light);
    padding: 12px 0;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 480px) {
    h1 { font-size: 2rem; }
    .scale-btn { padding: 10px 2px; font-size: 14px; }
  }
</style>
</head>
<body>

<div id="hero-section" class="hero">
  <div class="logo">Nudge</div>
  <p class="hero-eyebrow">NYC Concept Survey</p>
  <h1>Dating apps got us <em>talking.</em> What if they got us meeting?</h1>
  <p class="hero-sub">We're building something new. Help us shape it — takes about 5 minutes.</p>
  <div class="prize-pill">Enter to win a $100 Amazon gift card</div>
  <button class="cta-btn" onclick="startSurvey()">Take the survey</button>
  <p class="time-note">~5 minutes &nbsp;·&nbsp; completely anonymous</p>
</div>

<div id="survey-section" class="survey-section" style="display:none;">
  <div class="progress-wrap">
    <div class="progress-meta">
      <span id="step-counter">Step 1 of 7</span>
      <span id="pct-label">0%</span>
    </div>
    <div class="progress-track"><div class="progress-fill" id="prog"></div></div>
  </div>

  <div class="step active" id="s0">
    <div class="step-tag">Your details</div>
    <h2 class="q-title">First, a few basics</h2>
    <p class="q-sub">Only used to contact you if you win. We won't reach out for anything else.</p>
    <label class="field-label">First name</label>
    <input class="text-input" id="f-name" type="text" placeholder="e.g. Jamie" autocomplete="given-name">
    <label class="field-label">Age</label>
    <input class="text-input age-input" id="f-age" type="number" placeholder="26" min="18" max="99">
    <label class="field-label">Email address</label>
    <input class="text-input" id="f-email" type="email" placeholder="you@example.com" autocomplete="email">
    <div class="err" id="err0"></div>
    <div class="btn-row"><button class="btn-next" onclick="goNext(0)">Start survey →</button></div>
  </div>

  <div class="step" id="s1">
    <div class="step-tag">Dating habits · 1 of 5</div>
    <h2 class="q-title">Which dating apps do you use or have used?</h2>
    <p class="q-sub">Select all that apply.</p>
    <div class="opts" id="q1">
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Tinder</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Hinge</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Bumble</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Happn</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Coffee Meets Bagel</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>Other</div>
      <div class="opt" onclick="toggleMulti(this)"><div class="opt-indicator opt-sq"></div>I don't use dating apps</div>
    </div>
    <div class="btn-row">
      <button class="btn-back" onclick="goBack(1)">Back</button>
      <button class="btn-next" onclick="goNext(1)">Next →</button>
    </div>
  </div>

  <div class="step" id="s2">
    <div class="step-tag">Dating habits · 2 of 5</div>
    <h2 class="q-title">How satisfied are you with dating apps overall?</h2>
    <p class="q-sub">1 = very unsatisfied &nbsp;·&nbsp; 5 = very satisfied</p>
    <div class="scale-row" id="q2">
      <button class="scale-btn" onclick="selectScale(this,'q2')">1</button>
      <button class="scale-btn" onclick="selectScale(this,'q2')">2</button>
      <button class="scale-btn" onclick="selectScale(this,'q2')">3</button>
      <button class="scale-btn" onclick="selectScale(this,'q2')">4</button>
      <button class="scale-btn" onclick="selectScale(this,'q2')">5</button>
    </div>
    <div class="scale-labels"><span>Very unsatisfied</span><span>Very satisfied</span></div>
    <div class="btn-row">
      <button class="btn-back" onclick="goBack(2)">Back</button>
      <button class="btn-next" onclick="goNext(2)">Next →</button>
    </div>
  </div>

  <div class="step" id="s3">
    <div class="step-tag">Dating habits · 3 of 5</div>
    <h2 class="q-title">What's your biggest frustration with dating apps?</h2>
    <p class="q-sub">Pick the one that resonates most.</p>
    <div class="opts" id="q3">
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>Matches never lead to actual dates</div>
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>Conversations feel shallow or scripted</div>
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>People seem different in person than on their profile</div>
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>It feels too transactional or gamified</div>
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>Too much time for too little return</div>
      <div class="opt" onclick="selectOne(this,'q3')"><div class="opt-indicator"></div>I don't have a major frustration</div>
    </div>
    <div class="btn-row">
      <button class="btn-back" onclick="goBack(3)">Back</button>
      <button class="btn-next" onclick="goNext(3)">Next →</button>
    </div>
  </div>

  <div class="step" id="s4">
    <div class="step-tag">In-person dating · 4 of 5</div>
    <h2 class="q-title">How comfortable are you approaching someone you find attractive in public?</h2>
    <p class="q-sub">1 = very uncomfortable &nbsp;·&nbsp; 5 = very comfortable</p>
    <div class="scale-row" id="q4">
      <button class="scale-btn" onclick="selectScale(this,'q4')">1</button>
      <button class="scale-btn" onclick="selectScale(this,'q4')">2</button>
      <button class="scale-btn" onclick="selectScale(this,'q4')">3</button>
      <button class="scale-btn" onclick="selectScale(this,'q4')">4</button>
      <button class="scale-btn" onclick="selectScale(this,'q4')">5</button>
    </div>
    <div class="scale-labels"><span>Very uncomfortable</span><span>Very comfortable</span></div>
    <h2 class="q-title" style="margin-top:8px;">What's the biggest barrier to approaching in person?</h2>
    <p class="q-sub">Pick one.</p>
    <div class="opts" id="q4b">
      <div class="opt" onclick="selectOne(this,'q4b')"><div class="opt-indicator"></div>Fear of rejection</div>
      <div class="opt" onclick="selectOne(this,'q4b')"><div class="opt-indicator"></div>Not knowing if they're interested</div>
      <div class="opt" onclick="selectOne(this,'q4b')"><div class="opt-indicator"></div>Worry about coming across as creepy</div>
      <div class="opt" onclick="selectOne(this,'q4b')"><div class="opt-indicator"></div>I never know what to say</div>
      <div class="opt" onclick="selectOne(this,'q4b')"><div class="opt-indicator"></div>No real barrier — I'm comfortable</div>
    </div>
    <div class="btn-row">
      <button class="btn-back" onclick="goBack(4)">Back</button>
      <button class="btn-next" onclick="goNext(4)">Next →</button>
    </div>
  </div>

  <div class="step" id="s5">
    <div class="step-tag">The concept · 5 of 5</div>
    <h2 class="q-title">Here's the idea</h2>
    <div class="concept-box">
      You browse profiles and like people anonymously — just like any app. When two people mutually like each other, they match. After chatting a little, each person can toggle that they're <strong>open to being approached in person.</strong> When both have toggled on and you're physically nearby, you both get a <strong>simultaneous notification</strong> — a green light — letting you know the moment is there. No exact location is shared. Just the signal.
    </div>
    <h2 class="q-title" style="font-size:17px;">How appealing does this sound?</h2>
    <p class="q-sub">1 = not at all &nbsp;·&nbsp; 5 = very appealing</p>
    <div class="scale-row" id="q5a">
      <button class="scale-btn" onclick="selectScale(this,'q5a')">1</button>
      <button class="scale-btn" onclick="selectScale(this,'q5a')">2</button>
      <button class="scale-btn" onclick="selectScale(this,'q5a')">3</button>
      <button class="scale-btn" onclick="selectScale(this,'q5a')">4</button>
      <button class="scale-btn" onclick="selectScale(this,'q5a')">5</button>
    </div>
    <div class="scale-labels" style="margin-bottom:20px;"><span>Not appealing</span><span>Very appealing</span></div>
    <h2 class="q-title" style="font-size:17px;">Would you feel safe using this?</h2>
    <div class="opts" id="q5b">
      <div class="opt" onclick="selectOne(this,'q5b')"><div class="opt-indicator"></div>Yes — mutual consent makes it feel safe</div>
      <div class="opt" onclick="selectOne(this,'q5b')"><div class="opt-indicator"></div>Mostly — I'd want to know more about location privacy</div>
      <div class="opt" onclick="selectOne(this,'q5b')"><div class="opt-indicator"></div>Unsure — I'd need to try it first</div>
      <div class="opt" onclick="selectOne(this,'q5b')"><div class="opt-indicator"></div>Not really — the in-person element concerns me</div>
    </div>
    <h2 class="q-title" style="font-size:17px;">What excites you most about this idea?</h2>
    <div class="opts" id="q5c">
      <div class="opt" onclick="selectOne(this,'q5c')"><div class="opt-indicator"></div>Knowing they're already interested before I approach</div>
      <div class="opt" onclick="selectOne(this,'q5c')"><div class="opt-indicator"></div>A real encounter vs endless texting</div>
      <div class="opt" onclick="selectOne(this,'q5c')"><div class="opt-indicator"></div>Meeting people in places I already go</div>
      <div class="opt" onclick="selectOne(this,'q5c')"><div class="opt-indicator"></div>Nothing — I'm not excited by this concept</div>
    </div>
    <h2 class="q-title" style="font-size:17px;">Any other thoughts or concerns?</h2>
    <p class="q-sub">Optional but hugely helpful.</p>
    <textarea class="text-area" id="q5d" placeholder="Share anything on your mind..."></textarea>
    <div class="err" id="err5"></div>
    <div class="btn-row">
      <button class="btn-back" onclick="goBack(5)">Back</button>
      <button class="btn-next" id="submit-btn" onclick="submitSurvey()">Submit &amp; enter draw →</button>
    </div>
    <p class="submitting" id="submitting-msg" style="display:none;">Submitting your response...</p>
  </div>

  <div class="step" id="s-done">
    <div class="done-wrap">
      <div class="done-icon">✓</div>
      <h2 class="done-title">You're in the draw.</h2>
      <p class="done-sub">Thank you — this kind of feedback is exactly what we need to build something people actually want. We'll pick a winner at random and reach out within 4 weeks.</p>
      <div class="done-note">Winner selected from fully completed responses only. One entry per person. $100 Amazon gift card delivered digitally.</div>
    </div>
  </div>
</div>

<script>
const AIRTABLE_TOKEN = 'patxVN016nzCicGiX';
const BASE_ID = 'app0WMVpbZhaKE2as';
const TABLE_ID = 'tbl2zfXDlfdhSmICe';
const TOTAL_STEPS = 6;

let current = 0;
const answers = {};

function startSurvey() {
  document.getElementById('hero-section').style.display = 'none';
  document.getElementById('survey-section').style.display = 'block';
  window.scrollTo(0,0);
}

function updateProgress(step) {
  const pct = Math.round((step / TOTAL_STEPS) * 100);
  document.getElementById('prog').style.width = pct + '%';
  document.getElementById('pct-label').textContent = pct + '%';
  document.getElementById('step-counter').textContent = step === 0 ? 'Your details' : 'Step ' + step + ' of ' + (TOTAL_STEPS - 1);
}

function showStep(n) {
  document.querySelectorAll('.step').forEach(s => s.classList.remove('active'));
  const el = document.getElementById(n < TOTAL_STEPS ? 's' + n : 's-done');
  if (el) el.classList.add('active');
  updateProgress(n);
  window.scrollTo(0, 0);
}

function selectOne(el, group) {
  document.querySelectorAll('#' + group + ' .opt').forEach(o => o.classList.remove('sel'));
  el.classList.add('sel');
}

function toggleMulti(el) {
  el.classList.toggle('sel');
}

function selectScale(el, group) {
  document.querySelectorAll('#' + group + ' .scale-btn').forEach(b => b.classList.remove('sel'));
  el.classList.add('sel');
}

function getSelected(group) {
  return [...document.querySelectorAll('#' + group + ' .sel')].map(o => o.textContent.trim()).join(', ');
}

function getScale(group) {
  const sel = document.querySelector('#' + group + ' .scale-btn.sel');
  return sel ? sel.textContent.trim() : '';
}

function showErr(id, msg) {
  const el = document.getElementById(id);
  if (el) { el.textContent = msg; el.style.display = 'block'; }
}

function clearErr(id) {
  const el = document.getElementById(id);
  if (el) el.style.display = 'none';
}

function goNext(step) {
  if (step === 0) {
    const name = document.getElementById('f-name').value.trim();
    const age = document.getElementById('f-age').value.trim();
    const email = document.getElementById('f-email').value.trim();
    if (!name || !age || !email) { showErr('err0', 'Please fill in all fields.'); return; }
    if (isNaN(age) || +age < 18 || +age > 99) { showErr('err0', 'Please enter a valid age (18 or over).'); return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showErr('err0', 'Please enter a valid email address.'); return; }
    clearErr('err0');
    answers.name = name; answers.age = age; answers.email = email;
  }
  if (step === 2 && !getScale('q2')) { alert('Please select a rating.'); return; }
  if (step === 3 && !getSelected('q3')) { alert('Please select an option.'); return; }
  if (step === 4 && (!getScale('q4') || !getSelected('q4b'))) { alert('Please answer both questions.'); return; }
  current = step + 1;
  showStep(current);
}

function goBack(step) {
  current = step - 1;
  showStep(current);
}

async function submitSurvey() {
  const appeal = getScale('q5a');
  const safe = getSelected('q5b');
  const exciting = getSelected('q5c');
  if (!appeal || !safe || !exciting) {
    showErr('err5', 'Please answer all questions before submitting.');
    return;
  }
  clearErr('err5');

  document.getElementById('submit-btn').disabled = true;
  document.getElementById('submitting-msg').style.display = 'block';

  const fields = {
    'Name': answers.name,
    'Age': parseInt(answers.age),
    'Email': answers.email,
    'Apps Used': getSelected('q1') || 'None selected',
    'App Satisfaction': getScale('q2'),
    'Biggest Frustration': getSelected('q3'),
    'Approach Comfort': getScale('q4'),
    'Approach Barrier': getSelected('q4b'),
    'Concept Appeal': appeal,
    'Feels Safe': safe,
    'Most Exciting': exciting,
    'Open Feedback': document.getElementById('q5d').value.trim() || '—'
  };

  try {
    const res = await fetch(`https://api.airtable.com/v0/${BASE_ID}/${TABLE_ID}`, {
      method: 'POST',
      headers: {
        'Authorization': 'Bearer ' + AIRTABLE_TOKEN,
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ fields })
    });
    if (!res.ok) throw new Error('Airtable error ' + res.status);
  } catch (e) {
    console.error(e);
  }

  showStep(TOTAL_STEPS);
}

updateProgress(0);
</script>
